# ─── App ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://mayalu:secret@localhost:5432/mayalu_wears
DATABASE_MAX_CONNECTIONS=10

# ─── JWT ─────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_64_CHAR_RANDOM_HEX_STRING_MINIMUM_32_CHARS_REQUIRED
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRE_DAYS=30
JWT_ISSUER=mayalu-wears
JWT_AUDIENCE=mayalu-wears-app

# ─── OTP ─────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60

# ─── SMS ─────────────────────────────────────────────────────────
SMS_PROVIDER=mock
# Set to 'sparrow' in production
# SPARROW_SMS_TOKEN=your_sparrow_token_here
# SPARROW_SMS_FROM=MayaluWears
SMS_DEBUG=true

# ─── Cloudinary ───────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=mayalu-wears

# ─── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100
AUTH_THROTTLE_TTL=60000
AUTH_THROTTLE_MAX=5

# ─── Admin ────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_SECRET_KEY=CHANGE_ME_TO_32_CHAR_RANDOM_HEX_STRING

# ─── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_PRETTY=true
-e 
# Comma-separated user UUIDs with platform admin role
ADMIN_USER_IDS=
