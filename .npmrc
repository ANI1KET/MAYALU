# pnpm configuration for Mayalu Wears Backend
# These packages require native compilation (node-gyp / esbuild binaries).
# Explicitly approved so pnpm --frozen-lockfile CI installs work without prompts.
# See: https://pnpm.io/npmrc#ignored-built-dependencies

# Allow build scripts for packages that require them.
# This replaces running `pnpm approve-builds` interactively.
ignore-scripts=false
